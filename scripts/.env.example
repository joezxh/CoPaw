# CoPaw Enterprise 环境变量配置模板
# 复制此文件为 .env 并修改相应的值

# ========================================
# 数据库配置 (PostgreSQL)
# ========================================
COPAW_DB_HOST=localhost
COPAW_DB_PORT=5432
COPAW_DB_DATABASE=copaw_enterprise
COPAW_DB_USERNAME=copaw
COPAW_DB_PASSWORD=your_secure_password_here

# ========================================
# Redis 配置
# ========================================
COPAW_REDIS_HOST=localhost
COPAW_REDIS_PORT=6379
# COPAW_REDIS_PASSWORD=your_redis_password

# ========================================
# 安全配置
# ========================================
# JWT 密钥 - 生产环境必须修改为强密钥
COPAW_JWT_SECRET=super-secret-jwt-key-change-in-production

# 字段加密密钥 - 64位十六进制字符串 (32字节)
# 生成方法: python -c "import secrets; print(secrets.token_hex(32))"
COPAW_FIELD_ENCRYPT_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef

# ========================================
# 其他配置
# ========================================
# 启用企业版 (true/false)
COPAW_ENTERPRISE_ENABLED=true

# 日志级别 (debug/info/warning/error)
# COPAW_LOG_LEVEL=info

# 工作目录
# COPAW_WORKING_DIR=~/.copaw

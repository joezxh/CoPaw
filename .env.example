# CoPaw Environment Configuration Example
# Copy this file to .env and modify as needed

# CORS configuration for development
# Comma-separated list of allowed origins
# Example: http://localhost:5173 (Vite dev server), http://localhost:8088
COPAW_CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:8088,http://127.0.0.1:8088

# Enterprise mode (optional)
# Set to true/1/yes to enable enterprise features (PostgreSQL, Redis, JWT auth)
# COPAW_ENTERPRISE_ENABLED=false

# Log level (optional)
# Options: debug, info, warning, error
# COPAW_LOG_LEVEL=info

# Working directory (optional)
# COPAW_WORKING_DIR=~/.copaw

# Database configuration (for enterprise mode)
# COPAW_DB_HOST=localhost
# COPAW_DB_PORT=5432
# COPAW_DB_NAME=copaw
# COPAW_DB_USER=copaw
# COPAW_DB_PASSWORD=your_password

# Redis configuration (for enterprise mode)
# COPAW_REDIS_HOST=localhost
# COPAW_REDIS_PORT=6379
# COPAW_REDIS_PASSWORD=your_password
